{
  "meta": {
    "project": "CAAVI Comercializadora",
    "version": "1.0.0",
    "created": "2026-03-30",
    "description": "Design tokens — Sistema de diseño completo para CAAVI"
  },
  "color": {
    "primary": {
      "50":  "#EFF6FF",
      "100": "#DBEAFE",
      "200": "#BFDBFE",
      "300": "#93C5FD",
      "400": "#60A5FA",
      "500": "#3B82F6",
      "600": "#2563EB",
      "700": "#1D4ED8",
      "800": "#1E40AF",
      "900": "#1E3A8A",
      "950": "#172554"
    },
    "navy": {
      "50":  "#EEF2FF",
      "100": "#D4DCF7",
      "200": "#A9B9EF",
      "300": "#7E96E7",
